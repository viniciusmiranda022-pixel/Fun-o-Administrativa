<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TISCO | On Demand Recovery"
        Height="850" Width="1400" WindowStartupLocation="CenterScreen" Background="#F4F5F7">

    <Window.Resources>
        <SolidColorBrush x:Key="QuestBlue" Color="#004B8D"/>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/><Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/><Setter Property="Foreground" Value="#555555"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#F0F0F0"/></Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="240"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D1D1D1" BorderThickness="0,0,1,0">
            <StackPanel>
                <StackPanel Margin="20,20,20,30">
                    <TextBlock Text="TISCO" FontWeight="Bold" FontSize="20" Foreground="{StaticResource QuestBlue}"/>
                    <TextBlock Text="On Demand Recovery" FontSize="11" Foreground="#888888"/>
                </StackPanel>
                <Button x:Name="MenuDash" Content="Dashboard" Style="{StaticResource MenuBtn}"/>
                <Button x:Name="MenuTenants" Content="Tenants" Style="{StaticResource MenuBtn}"/>
                <Separator Margin="15,10"/>
                <Button x:Name="MenuBackups" Content="Backups" Style="{StaticResource MenuBtn}"/>
                <Button x:Name="MenuUnpacked" Content="Unpacked Objects" Style="{StaticResource MenuBtn}"/>
                <Button x:Name="MenuDifferences" Content="Differences" Style="{StaticResource MenuBtn}"/>
                <Separator Margin="15,10"/>
                <Button x:Name="MenuEvents" Content="Events" Style="{StaticResource MenuBtn}"/>
                <Button x:Name="MenuTasks" Content="Tasks" Style="{StaticResource MenuBtn}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions><RowDefinition Height="60"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="White" BorderBrush="#D1D1D1" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock x:Name="TxtPageTitle" Text="Dashboard" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtStatus" Text="Status: Pronto" Margin="0,0,20,0" VerticalAlignment="Center" Foreground="#666666"/>
                        <Button x:Name="BtnConnect" Content="Connect Tenant" Padding="15,6" Background="{StaticResource QuestBlue}" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="20">
                <Grid x:Name="ViewDashboard" Visibility="Visible">
                    <WrapPanel>
                        <Border Width="200" Height="80" Background="White" BorderBrush="#D1D1D1" BorderThickness="1" Margin="0,0,10,0" Padding="15">
                            <StackPanel><TextBlock Text="TENANTS CONFIGURADOS" FontSize="10"/><TextBlock x:Name="DashStatTenants" Text="1" FontSize="24" FontWeight="Bold" Foreground="{StaticResource QuestBlue}"/></StackPanel>
                        </Border>
                        <Border Width="200" Height="80" Background="White" BorderBrush="#D1D1D1" BorderThickness="1" Padding="15">
                            <StackPanel><TextBlock Text="BACKUPS (Fase 1)" FontSize="10"/><TextBlock x:Name="DashStatBackups" Text="0" FontSize="24" FontWeight="Bold"/></StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>

                <Grid x:Name="ViewTenants" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Configuraçăo de Onboarding" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Button x:Name="BtnAutoSetupTenant" Content="Add &amp; Configure Tenant" Width="200" HorizontalAlignment="Left" Background="{StaticResource QuestBlue}" Foreground="White" Height="35" BorderThickness="0"/>
                        <GroupBox Header="Parâmetros Atuais" Margin="0,20,0,0" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0"><TextBlock Text="Tenant ID"/><TextBox x:Name="TxtTenantId" Padding="5"/></StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0"><TextBlock Text="Client ID"/><TextBox x:Name="TxtClientId" Padding="5"/></StackPanel>
                                <StackPanel Grid.Column="2"><TextBlock Text="Thumbprint"/><TextBox x:Name="TxtThumbprint" Padding="5"/></StackPanel>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </Grid>

                <Grid x:Name="ViewBackups" Visibility="Collapsed">
                    <DataGrid x:Name="GridBackups" AutoGenerateColumns="False" Background="White" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Data do Snapshot" Binding="{Binding Name}" Width="250"/>
                            <DataGridTextColumn Header="Caminho Completo" Binding="{Binding FullName}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="ViewDifferences" Visibility="Collapsed">
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="200"/></Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="TxtSnapshotFolder" Width="350" Margin="0,0,10,0" ToolTip="Arraste ou cole o caminho do backup aqui"/>
                        <Button x:Name="BtnCompare" Content="Run Compare" Width="120" Background="{StaticResource QuestBlue}" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="BtnRestoreSelected" Content="Restore Selected" Width="130" Margin="10,0,0,0" Background="#107C41" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                    <DataGrid x:Name="GridRoles" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Administrative Function" Binding="{Binding RoleName}" Width="*"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtBackupDetails" Margin="0,0,5,0" Background="#2D2D30" Foreground="White" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                        <TextBox x:Name="TxtCurrentDetails" Grid.Column="1" Margin="5,0,0,0" Background="#2D2D30" Foreground="White" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Grid>

                <Grid x:Name="ViewUnpacked" Visibility="Collapsed"><TextBlock Text="Visualizaçăo de Objetos Detalhada"/></Grid>
                <Grid x:Name="ViewEvents" Visibility="Collapsed"><TextBlock Text="Logs Operacionais"/></Grid>
                <Grid x:Name="ViewTasks" Visibility="Collapsed"><TextBlock Text="Histórico de Tarefas"/></Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>