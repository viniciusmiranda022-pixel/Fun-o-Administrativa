<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TISCO | On Demand Recovery"
        Height="920" Width="1580" WindowStartupLocation="CenterScreen" Background="#EEF1F5"
        MinHeight="800" MinWidth="1320" FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBackground" Color="#1E2024"/>
        <SolidColorBrush x:Key="SidebarText" Color="#D1D5DB"/>
        <SolidColorBrush x:Key="QuestBlue" Color="#0077B8"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource QuestBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource QuestBlue}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="120"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0369A1"/>
                    <Setter Property="BorderBrush" Value="#0369A1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F4F6"/>
                    <Setter Property="BorderBrush" Value="#C7CDD6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarMenuButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SidebarBorder" Background="Transparent" CornerRadius="4">
                            <ContentPresenter Margin="0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SidebarBorder" Property="Background" Value="#2B2F36"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#F3F4F6"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" Padding="10,6" Margin="0,0,16,0">
                            <ContentPresenter x:Name="ContentSite" HorizontalAlignment="Center" VerticalAlignment="Center" ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource QuestBlue}"/>
                                <Setter Property="Foreground" Value="{StaticResource QuestBlue}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#0C4A6E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource SidebarBackground}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TISCO" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="Security Management Platform" FontSize="16" Foreground="#E5E7EB"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Identity Recovery for Microsoft Entra ID" VerticalAlignment="Center" FontSize="16" Foreground="#7FD5FF"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" BorderBrush="#31343B" BorderThickness="0,0,1,0">
                <StackPanel Margin="18,18,18,0">
                    <TextBlock Text="RECOVER" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Guided workflow" Foreground="{StaticResource SidebarText}" Margin="0,14,0,10" FontSize="13"/>
                    <Button Content="1) Connect tenant" Style="{StaticResource SidebarMenuButton}" IsEnabled="False"/>
                    <Button Content="2) Load snapshot" Style="{StaticResource SidebarMenuButton}" IsEnabled="False"/>
                    <Button Content="3) Compare differences" Style="{StaticResource SidebarMenuButton}" IsEnabled="False"/>
                    <Button Content="4) Restore role" Style="{StaticResource SidebarMenuButton}" IsEnabled="False" Margin="0,0,0,15"/>
                    <Separator Margin="0,0,0,10"/>
                    <TextBlock Text="Replication status" Foreground="{StaticResource SidebarText}" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtReplicationStatus" Text="App Registration replication: waiting to start." TextWrapping="Wrap" Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="20,20,20,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="18,14" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Administrative Functions Compare and Restore" FontSize="28" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="TxtStatus" Text="Status: ready." Foreground="#4B5563" Margin="0,6,0,0" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="BtnHamburger" Content="☰ Actions" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0">
                                <Button.ContextMenu>
                                    <ContextMenu x:Name="ActionMenu">
                                        <MenuItem x:Name="MnuConnectTenant" Header="Connect Tenant"/>
                                        <MenuItem x:Name="MnuOpenTenantsTab" Header="Open TENANTS tab"/>
                                        <Separator/>
                                        <MenuItem x:Name="MnuManageBackups" Header="Manage Backups"/>
                                        <MenuItem x:Name="MnuRunCompare" Header="Run Compare"/>
                                        <MenuItem x:Name="MnuRestoreSelected" Header="Restore Selected"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                            <Button x:Name="BtnConnect" Content="Connect Tenant" Style="{StaticResource PrimaryButton}" Visibility="Collapsed"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="16">
                    <TabControl x:Name="MainTabs">
                        <TabItem Header="BACKUPS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button x:Name="BtnLoadBackups" Content="Manage Backups" Style="{StaticResource PrimaryButton}"/>
                                    <Button x:Name="BtnRefreshBackups" Content="Refresh" Style="{StaticResource SecondaryButton}"/>
                                </StackPanel>
                                <DataGrid x:Name="GridBackups" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="240"/>
                                        <DataGridTextColumn Header="CollectedAt (manifest)" Binding="{Binding CollectedAt}" Width="250"/>
                                        <DataGridTextColumn Header="SnapshotFolder (FullName)" Binding="{Binding FullName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="DIFFERENCES">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="220"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <TextBlock Text="Snapshot folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtSnapshotFolder" Width="500" Margin="0,0,8,0" Padding="6,4"/>
                                    <Button x:Name="BtnBrowseSnapshot" Content="Select Folder" Style="{StaticResource SecondaryButton}"/>
                                    <Button x:Name="BtnCompare" Content="Run Compare" Style="{StaticResource PrimaryButton}"/>
                                    <Button x:Name="BtnRestoreSelected" Content="Restore Selected" Background="#0A8F42" Foreground="White" BorderBrush="#0B7A3A" BorderThickness="1" Padding="14,7" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                                <Setter Property="Background" Value="#0A8F42"/>
                                                <Setter Property="BorderBrush" Value="#0B7A3A"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#087138"/>
                                                        <Setter Property="BorderBrush" Value="#087138"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>

                                <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,0,0,12">
                                    <WrapPanel>
                                        <TextBlock Text="Name filter:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="TxtFilterRoleName" Width="220" Margin="0,0,10,0" Padding="6,4"/>
                                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CmbStatusFilter" Width="130" SelectedIndex="0" Margin="0,0,10,0">
                                            <ComboBoxItem Content="All"/>
                                            <ComboBoxItem Content="Changed"/>
                                            <ComboBoxItem Content="New"/>
                                            <ComboBoxItem Content="Removed"/>
                                            <ComboBoxItem Content="Equal"/>
                                        </ComboBox>
                                        <Button x:Name="BtnApplyFilter" Content="Apply Filter" Style="{StaticResource SecondaryButton}"/>
                                        <Button x:Name="BtnExport" Content="Export Diff" Style="{StaticResource SecondaryButton}"/>
                                    </WrapPanel>
                                </Border>

                                <DataGrid x:Name="GridRoles" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Background="White" Margin="0,0,0,12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Administrative Function" Binding="{Binding RoleName}" Width="*"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding RoleType}" Width="100"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                        <DataGridTextColumn Header="Definition Changed" Binding="{Binding DefinitionChanged}" Width="130"/>
                                        <DataGridTextColumn Header="Assignments Changed" Binding="{Binding AssignmentsChanged}" Width="130"/>
                                        <DataGridTextColumn Header="Difference Count" Binding="{Binding DifferenceCount}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Backup" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBox Grid.Row="1" x:Name="TxtBackupDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" CornerRadius="4" Padding="8" Margin="8,0,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Current Tenant" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                            <TextBox Grid.Row="1" x:Name="TxtCurrentDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="TENANTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Provide authentication and app-only operation inputs." FontWeight="SemiBold" FontSize="14"/>
                                <Grid Grid.Row="1" Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0"><TextBlock Text="Tenant ID (required)"/><TextBox x:Name="TxtTenantId" Padding="6"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0"><TextBlock Text="Client ID"/><TextBox x:Name="TxtClientId" Padding="6"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Certificate Thumbprint"/><TextBox x:Name="TxtThumbprint" Padding="6"/></StackPanel>
                                </Grid>
                                <TextBox Grid.Row="2" x:Name="TxtTenantNotes" Margin="0,16,0,0" Height="110" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="10"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="UNPACKED OBJECTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Detailed fields for the selected item in Differences." Foreground="#374151" Margin="0,0,0,8"/>
                                <DataGrid x:Name="GridUnpackedObjects" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="180"/>
                                        <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="300"/>
                                        <DataGridTextColumn Header="Backup" Binding="{Binding BackupValue}" Width="*"/>
                                        <DataGridTextColumn Header="Current Tenant" Binding="{Binding CurrentValue}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="EVENTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="170"/>
                                </Grid.RowDefinitions>
                                <DataGrid x:Name="GridEvents" AutoGenerateColumns="False" IsReadOnly="True" Background="White" Margin="0,0,0,8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="180"/>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBox x:Name="TxtEventDetails" Grid.Row="1" Background="#111827" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="Wrap"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="TASKS">
                            <Grid Margin="10">
                                <DataGrid x:Name="GridTasks" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="180"/>
                                        <DataGridTextColumn Header="Task" Binding="{Binding Task}" Width="240"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
