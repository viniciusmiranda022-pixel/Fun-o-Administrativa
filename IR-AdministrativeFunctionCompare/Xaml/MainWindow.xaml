<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Administrative Function Compare Console"
        Height="860"
        Width="1420"
        MinHeight="760"
        MinWidth="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6"
        FontFamily="Segoe UI">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#107C41"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#C57D00"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#D83B01"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#616161"/>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#1F2937"/>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#111827"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="250"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Administrative Function Compare Console" FontSize="24" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtStatus" Text="Status: aguardando início." Margin="0,4,0,0" Foreground="{StaticResource MutedBrush}"/>
                </StackPanel>

                <Border Grid.Column="1" Background="#F3F9FF" BorderBrush="#B6DCFA" BorderThickness="1" CornerRadius="4" Padding="10,6" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tenant obrigatório" FontWeight="SemiBold" Foreground="#075985"/>
                        <TextBlock Text=" • " Foreground="#075985"/>
                        <TextBlock Text="Fluxo guiado" Foreground="#075985"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="6" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Tenant ID *" FontWeight="SemiBold" Grid.Row="0" Grid.Column="0" Margin="0,0,0,4"/>
                <TextBlock Text="Client ID (App) *" FontWeight="SemiBold" Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"/>
                <TextBlock Text="Thumbprint Certificado *" FontWeight="SemiBold" Grid.Row="0" Grid.Column="2" Margin="0,0,0,4"/>
                <TextBlock Text="Snapshot selecionado" FontWeight="SemiBold" Grid.Row="0" Grid.Column="3" Margin="0,0,0,4"/>

                <TextBox x:Name="TxtTenantId" Grid.Row="1" Grid.Column="0" Margin="0,0,15,10"/>
                <TextBox x:Name="TxtClientId" Grid.Row="1" Grid.Column="1" Margin="0,0,15,10"/>
                <TextBox x:Name="TxtThumbprint" Grid.Row="1" Grid.Column="2" Margin="0,0,15,10"/>

                <Grid Grid.Row="1" Grid.Column="3" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtSnapshotFolder" Grid.Column="0" Margin="0,0,10,0" IsReadOnly="True" Background="#F9FAFB"/>
                    <Button x:Name="BtnBrowseSnapshot" Content="..." Grid.Column="1" Width="34" Style="{StaticResource GhostButton}" Margin="0"/>
                </Grid>

                <TextBlock x:Name="TxtReplicationStatus"
                           Grid.Row="2"
                           Grid.ColumnSpan="4"
                           Text="Replicação de App Registration: aguardando."
                           Foreground="#7C2D12"
                           Background="#FFF7ED"
                           Padding="8,6"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" CornerRadius="6" Padding="14" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Fluxo" FontWeight="Bold" FontSize="16" Margin="0,0,0,12"/>
                    <Button x:Name="BtnConnect" Content="1. Autenticar e validar tenant"/>
                    <Button x:Name="BtnLoadBackups" Content="2. Carregar backups" Background="#2563EB"/>
                    <Button x:Name="BtnCompare" Content="3. Abrir Differences" Background="#0EA5E9"/>
                    <Button x:Name="BtnRestoreSelected" Content="4. Restore Selected" Background="{StaticResource DangerBrush}" IsEnabled="False" Margin="0,0,0,16"/>

                    <Separator Margin="0,0,0,16"/>
                    <TextBlock Text="Filtros" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
                    <TextBlock Text="Nome da Função" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtFilterRoleName"/>
                    <TextBlock Text="Status" Margin="0,0,0,3"/>
                    <ComboBox x:Name="CmbStatusFilter">
                        <ComboBoxItem Content="Todos" IsSelected="True"/>
                        <ComboBoxItem Content="Igual"/>
                        <ComboBoxItem Content="Alterada"/>
                        <ComboBoxItem Content="Nova"/>
                        <ComboBoxItem Content="Removida"/>
                    </ComboBox>
                    <Button x:Name="BtnApplyFilter" Content="Aplicar filtro" Style="{StaticResource GhostButton}"/>
                    <Button x:Name="BtnExport" Content="Exportar relatório" Background="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="White" CornerRadius="6" Padding="10">
                <TabControl x:Name="MainTabs">
                    <TabItem Header="Backups">
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                                <TextBlock Text="Origem fixa: C:\ProgramData\Quest\IR-AdministrativeFunctionBackup\Exports" VerticalAlignment="Center" Foreground="#374151"/>
                                <Button x:Name="BtnRefreshBackups" Content="Atualizar" Width="100" Margin="12,0,0,0" Style="{StaticResource GhostButton}"/>
                            </StackPanel>
                            <DataGrid x:Name="GridBackups" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" AlternatingRowBackground="#F9FAFB">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="200"/>
                                    <DataGridTextColumn Header="Coletado em" Binding="{Binding CollectedAt}" Width="230"/>
                                    <DataGridTextColumn Header="Pasta completa" Binding="{Binding FullName}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Differences">
                        <DataGrid x:Name="GridRoles"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  BorderThickness="1"
                                  BorderBrush="#E5E7EB"
                                  RowHeight="28"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#E5E7EB"
                                  AlternatingRowBackground="#F9FAFB"
                                  Background="White"
                                  Margin="6">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Função" Binding="{Binding RoleName}" Width="280"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding RoleType}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                                <DataGridTextColumn Header="Definição mudou?" Binding="{Binding DefinitionChanged}" Width="130"/>
                                <DataGridTextColumn Header="Atribuições mudaram?" Binding="{Binding AssignmentsChanged}" Width="150"/>
                                <DataGridTextColumn Header="Qtd. Diff" Binding="{Binding DifferenceCount}" Width="80"/>
                                <DataGridTextColumn Header="Resumo" Binding="{Binding Summary}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Events">
                        <Grid Margin="12">
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12" Background="#F9FAFB">
                                <TextBlock Text="Eventos exibem execuções de conexão, comparação e restore com data/hora no log da aplicação." TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Tasks">
                        <Grid Margin="12">
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12" Background="#F9FAFB">
                                <TextBlock Text="Tasks mostra o fluxo recomendado: autenticar tenant, selecionar backup, comparar e restaurar itens alterados." TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>

                    <TabItem Header="Unpacked Objects">
                        <Grid Margin="12">
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="4" Padding="12" Background="#F9FAFB">
                                <TextBlock Text="Unpacked Objects apresenta os detalhes técnicos (JSON) da função selecionada nos painéis inferiores." TextWrapping="Wrap"/>
                            </Border>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Detalhes do Backup (JSON)" Grid.Column="0" Margin="0,0,8,0" FontWeight="SemiBold">
                <TextBox x:Name="TxtBackupDetails" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" FontWeight="Normal" Background="#111827" Foreground="#E5E7EB" BorderThickness="0" Margin="5"/>
            </GroupBox>

            <GroupBox Header="Detalhes Atuais no Tenant (JSON)" Grid.Column="1" Margin="8,0,0,0" FontWeight="SemiBold">
                <TextBox x:Name="TxtCurrentDetails" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12" FontWeight="Normal" Background="#111827" Foreground="#E5E7EB" BorderThickness="0" Margin="5"/>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
