<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TISCO | On Demand Recovery"
        Height="880" Width="1460" WindowStartupLocation="CenterScreen" Background="#F3F4F6"
        MinHeight="760" MinWidth="1240">

    <Window.Resources>
        <SolidColorBrush x:Key="QuestBlue" Color="#004B8D"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#D9DCE2"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource QuestBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" BorderBrush="#D0D3D9" BorderThickness="0,0,1,0">
            <StackPanel Margin="16,20">
                <TextBlock Text="TISCO" FontWeight="Bold" FontSize="22" Foreground="{StaticResource QuestBlue}"/>
                <TextBlock Text="On Demand Recovery" FontSize="12" Foreground="#6A7280" Margin="0,0,0,16"/>
                <TextBlock Text="FLUXO GUIADO" FontSize="11" Foreground="#6A7280" Margin="0,0,0,6"/>
                <TextBlock Text="1) Conectar tenant" FontSize="12" Margin="0,0,0,3"/>
                <TextBlock Text="2) Carregar snapshot" FontSize="12" Margin="0,0,0,3"/>
                <TextBlock Text="3) Comparar diferenças" FontSize="12" Margin="0,0,0,3"/>
                <TextBlock Text="4) Restaurar função" FontSize="12" Margin="0,0,0,15"/>
                <Separator/>
                <TextBlock Text="Status de replicação" FontWeight="SemiBold" Margin="0,12,0,5"/>
                <TextBlock x:Name="TxtReplicationStatus" Text="Replicação de App Registration: aguardando início." TextWrapping="Wrap" Foreground="#4B5563"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="White" BorderBrush="#D0D3D9" BorderThickness="0,0,0,1" Padding="18,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Comparação e Restore de Administrative Functions" FontSize="19" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtStatus" Text="Status: pronto." Foreground="#4B5563" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnConnect" Content="Conectar Tenant" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl x:Name="MainTabs" Grid.Row="1" Margin="18">
                <TabItem Header="Backups">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="BtnLoadBackups" Content="Carregar Backups" Style="{StaticResource PrimaryButton}"/>
                            <Button x:Name="BtnRefreshBackups" Content="Atualizar" Background="#E5E7EB" Foreground="#111827" BorderThickness="0" Padding="14,8"/>
                        </StackPanel>
                        <DataGrid x:Name="GridBackups" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="230"/>
                                <DataGridTextColumn Header="CollectedAt (manifest)" Binding="{Binding CollectedAt}" Width="250"/>
                                <DataGridTextColumn Header="SnapshotFolder (FullName)" Binding="{Binding FullName}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Differences">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="190"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Snapshot Folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtSnapshotFolder" Width="500" Margin="0,0,8,0"/>
                            <Button x:Name="BtnBrowseSnapshot" Content="Selecionar" Background="#E5E7EB" Foreground="#111827" BorderThickness="0" Padding="12,8" Margin="0,0,8,0"/>
                            <Button x:Name="BtnCompare" Content="Run Compare" Style="{StaticResource PrimaryButton}"/>
                            <Button x:Name="BtnRestoreSelected" Content="Restore Selected" Background="#107C41" Foreground="White" BorderThickness="0" Padding="14,8"/>
                        </StackPanel>

                        <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <WrapPanel>
                                <TextBlock Text="Filtro nome:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtFilterRoleName" Width="220" Margin="0,0,10,0"/>
                                <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="CmbStatusFilter" Width="130" SelectedIndex="0" Margin="0,0,10,0">
                                    <ComboBoxItem Content="Todos"/>
                                    <ComboBoxItem Content="Alterada"/>
                                    <ComboBoxItem Content="Nova"/>
                                    <ComboBoxItem Content="Removida"/>
                                    <ComboBoxItem Content="Igual"/>
                                </ComboBox>
                                <Button x:Name="BtnApplyFilter" Content="Aplicar Filtro" Background="#E5E7EB" Foreground="#111827" BorderThickness="0" Padding="12,8" Margin="0,0,8,0"/>
                                <Button x:Name="BtnExport" Content="Exportar Diff" Background="#E5E7EB" Foreground="#111827" BorderThickness="0" Padding="12,8"/>
                            </WrapPanel>
                        </Border>

                        <DataGrid x:Name="GridRoles" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Margin="0,0,0,10">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Administrative Function" Binding="{Binding RoleName}" Width="*"/>
                                <DataGridTextColumn Header="Tipo" Binding="{Binding RoleType}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                <DataGridTextColumn Header="Definition Changed" Binding="{Binding DefinitionChanged}" Width="130"/>
                                <DataGridTextColumn Header="Assignments Changed" Binding="{Binding AssignmentsChanged}" Width="130"/>
                                <DataGridTextColumn Header="Difference Count" Binding="{Binding DifferenceCount}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <GroupBox Header="Backup" Margin="0,0,8,0">
                                <TextBox x:Name="TxtBackupDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </GroupBox>
                            <GroupBox Header="Tenant Atual" Grid.Column="1" Margin="8,0,0,0">
                                <TextBox x:Name="TxtCurrentDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                            </GroupBox>
                        </Grid>
                    </Grid>
                </TabItem>

                <TabItem Header="Tenants">
                    <Grid Margin="10">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <TextBlock Text="Informe os dados para autenticação e operação app-only." FontWeight="SemiBold"/>
                        <Grid Grid.Row="1" Margin="0,12,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0"><TextBlock Text="Tenant ID (obrigatório)"/><TextBox x:Name="TxtTenantId" Padding="6"/></StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,12,0"><TextBlock Text="Client ID"/><TextBox x:Name="TxtClientId" Padding="6"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="Certificate Thumbprint"/><TextBox x:Name="TxtThumbprint" Padding="6"/></StackPanel>
                        </Grid>
                        <Border Grid.Row="2" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="10" Margin="0,12,0,0">
                            <TextBlock Text="Segurança: o fluxo usa Service Principal + Certificate e não mantém credenciais globais no código." TextWrapping="Wrap" Foreground="#4B5563"/>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Unpacked Objects">
                    <Grid Margin="10">
                        <TextBlock TextWrapping="Wrap" Text="Unpacked Objects exibe o detalhamento do item selecionado na aba Differences. Selecione uma função para visualizar todos os atributos em Backup/Tenant Atual." Foreground="#374151"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Events">
                    <Grid Margin="10">
                        <TextBlock TextWrapping="Wrap" Text="Events registra mensagens operacionais no arquivo de log em ProgramData, incluindo autenticação, retries de replicação e execução de restore." Foreground="#374151"/>
                    </Grid>
                </TabItem>

                <TabItem Header="Tasks">
                    <Grid Margin="10">
                        <TextBlock TextWrapping="Wrap" Text="Tasks representa o histórico de ações: Connect, Compare, Export e Restore. Em caso de falha, consulte o log para troubleshooting guiado." Foreground="#374151"/>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>
