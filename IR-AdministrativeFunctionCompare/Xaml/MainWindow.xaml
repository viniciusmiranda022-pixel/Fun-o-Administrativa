<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TISCO | On Demand Recovery"
        Height="920" Width="1580" WindowStartupLocation="CenterScreen" Background="#EEF1F5"
        MinHeight="800" MinWidth="1320">

    <Window.Resources>
        <SolidColorBrush x:Key="QuestDark" Color="#2E3138"/>
        <SolidColorBrush x:Key="QuestBlue" Color="#0077B8"/>
        <SolidColorBrush x:Key="PanelBorder" Color="#D2D7DE"/>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource QuestBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#00679D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource QuestDark}">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TISCO" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,10,0"/>
                    <TextBlock Text="Security Management Platform" FontSize="16" Foreground="#E5E7EB"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="Identity Recovery for Microsoft Entra ID" VerticalAlignment="Center" FontSize="16" Foreground="#7FD5FF"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#3E4148" BorderBrush="#31343B" BorderThickness="0,0,1,0">
                <StackPanel Margin="18,18,18,0">
                    <TextBlock Text="RECOVER" Foreground="White" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="Fluxo guiado" Foreground="#D1D5DB" Margin="0,14,0,10" FontSize="13"/>
                    <TextBlock Text="1) Conectar tenant" Foreground="White" Margin="0,0,0,5" FontSize="14"/>
                    <TextBlock Text="2) Carregar snapshot" Foreground="White" Margin="0,0,0,5" FontSize="14"/>
                    <TextBlock Text="3) Comparar diferenças" Foreground="White" Margin="0,0,0,5" FontSize="14"/>
                    <TextBlock Text="4) Restaurar função" Foreground="White" Margin="0,0,0,15" FontSize="14"/>
                    <Separator Margin="0,0,0,10"/>
                    <TextBlock Text="Status de replicação" Foreground="#D1D5DB" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtReplicationStatus" Text="Replicação de App Registration: aguardando início." TextWrapping="Wrap" Foreground="White" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Grid Grid.Column="1" Margin="14,14,14,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="14,10" Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Comparação e Restore de Administrative Functions" FontSize="28" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="TxtStatus" Text="Status: pronto." Foreground="#4B5563" Margin="0,6,0,0" FontSize="14"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnConnect" Content="Conectar Tenant" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="8">
                    <TabControl x:Name="MainTabs">
                        <TabItem Header="BACKUPS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <Button x:Name="BtnLoadBackups" Content="Manage Backups" Style="{StaticResource PrimaryButton}"/>
                                    <Button x:Name="BtnRefreshBackups" Content="Atualizar" Background="#F3F4F6" BorderBrush="#C7CDD6" BorderThickness="1" Padding="14,7"/>
                                </StackPanel>
                                <DataGrid x:Name="GridBackups" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp}" Width="240"/>
                                        <DataGridTextColumn Header="CollectedAt (manifest)" Binding="{Binding CollectedAt}" Width="250"/>
                                        <DataGridTextColumn Header="SnapshotFolder (FullName)" Binding="{Binding FullName}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="DIFFERENCES">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="210"/>
                                </Grid.RowDefinitions>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Snapshot Folder:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtSnapshotFolder" Width="500" Margin="0,0,8,0" Padding="6,4"/>
                                    <Button x:Name="BtnBrowseSnapshot" Content="Selecionar" Background="#F3F4F6" BorderBrush="#C7CDD6" BorderThickness="1" Padding="12,7" Margin="0,0,8,0"/>
                                    <Button x:Name="BtnCompare" Content="Run Compare" Style="{StaticResource PrimaryButton}"/>
                                    <Button x:Name="BtnRestoreSelected" Content="Restore Selected" Background="#0A8F42" Foreground="White" BorderBrush="#0B7A3A" BorderThickness="1" Padding="14,7"/>
                                </StackPanel>

                                <Border Grid.Row="1" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="10" Margin="0,0,0,10">
                                    <WrapPanel>
                                        <TextBlock Text="Filtro nome:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBox x:Name="TxtFilterRoleName" Width="220" Margin="0,0,10,0" Padding="6,4"/>
                                        <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox x:Name="CmbStatusFilter" Width="130" SelectedIndex="0" Margin="0,0,10,0">
                                            <ComboBoxItem Content="Todos"/>
                                            <ComboBoxItem Content="Alterada"/>
                                            <ComboBoxItem Content="Nova"/>
                                            <ComboBoxItem Content="Removida"/>
                                            <ComboBoxItem Content="Igual"/>
                                        </ComboBox>
                                        <Button x:Name="BtnApplyFilter" Content="Aplicar Filtro" Background="#F3F4F6" BorderBrush="#C7CDD6" BorderThickness="1" Padding="12,7" Margin="0,0,8,0"/>
                                        <Button x:Name="BtnExport" Content="Exportar Diff" Background="#F3F4F6" BorderBrush="#C7CDD6" BorderThickness="1" Padding="12,7"/>
                                    </WrapPanel>
                                </Border>

                                <DataGrid x:Name="GridRoles" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Margin="0,0,0,10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Administrative Function" Binding="{Binding RoleName}" Width="*"/>
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding RoleType}" Width="100"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110"/>
                                        <DataGridTextColumn Header="Definition Changed" Binding="{Binding DefinitionChanged}" Width="130"/>
                                        <DataGridTextColumn Header="Assignments Changed" Binding="{Binding AssignmentsChanged}" Width="130"/>
                                        <DataGridTextColumn Header="Difference Count" Binding="{Binding DifferenceCount}" Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <GroupBox Header="Backup" Margin="0,0,8,0">
                                        <TextBox x:Name="TxtBackupDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                    </GroupBox>
                                    <GroupBox Header="Tenant Atual" Grid.Column="1" Margin="8,0,0,0">
                                        <TextBox x:Name="TxtCurrentDetails" Background="#1F2937" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap"/>
                                    </GroupBox>
                                </Grid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="TENANTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Informe os dados para autenticação e operação app-only." FontWeight="SemiBold" FontSize="14"/>
                                <Grid Grid.Row="1" Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0"><TextBlock Text="Tenant ID (obrigatório)"/><TextBox x:Name="TxtTenantId" Padding="6"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,12,0"><TextBlock Text="Client ID"/><TextBox x:Name="TxtClientId" Padding="6"/></StackPanel>
                                    <StackPanel Grid.Column="2"><TextBlock Text="Certificate Thumbprint"/><TextBox x:Name="TxtThumbprint" Padding="6"/></StackPanel>
                                </Grid>
                                <TextBox Grid.Row="2" x:Name="TxtTenantNotes" Margin="0,12,0,0" Height="110" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#F9FAFB" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Padding="8"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="UNPACKED OBJECTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Detalhes ricos do item selecionado em Differences." Foreground="#374151" Margin="0,0,0,8"/>
                                <DataGrid x:Name="GridUnpackedObjects" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Section" Binding="{Binding Section}" Width="180"/>
                                        <DataGridTextColumn Header="Field" Binding="{Binding Field}" Width="300"/>
                                        <DataGridTextColumn Header="Backup" Binding="{Binding BackupValue}" Width="*"/>
                                        <DataGridTextColumn Header="Tenant Atual" Binding="{Binding CurrentValue}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>

                        <TabItem Header="EVENTS">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="170"/>
                                </Grid.RowDefinitions>
                                <DataGrid x:Name="GridEvents" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1" Margin="0,0,0,8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="180"/>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBox x:Name="TxtEventDetails" Grid.Row="1" Background="#111827" Foreground="#E5E7EB" FontFamily="Consolas" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True" TextWrapping="Wrap"/>
                            </Grid>
                        </TabItem>

                        <TabItem Header="TASKS">
                            <Grid Margin="10">
                                <DataGrid x:Name="GridTasks" AutoGenerateColumns="False" IsReadOnly="True" Background="White" BorderBrush="{StaticResource PanelBorder}" BorderThickness="1">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="180"/>
                                        <DataGridTextColumn Header="Task" Binding="{Binding Task}" Width="240"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
